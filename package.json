{
  "name": "tinyurl-shortener",
  "version": "1.0.0",
  "description": "Scalable URL Shortener service with Postgres, Redis, Rate Limiting, Caching, and Analytics.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "worker:dev": "ts-node-dev --respawn --transpile-only src/worker/index.ts",
    "db:init": "ts-node-dev --transpile-only src/scripts/init-db.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ioredis": "^5.4.1",
    "pg": "^8.11.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.7",
    "@types/pg": "^8.11.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
